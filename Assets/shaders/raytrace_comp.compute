bool iter_poly_list(inout rand_state state, const hit_object h, const ray r, interval ray_t, inout hit_record rec)
{
    hit_record temp_rec = hit_record_new();
    bool hit_anything = false;
    float closest_so_far = ray_t.max;
    int start = h.poly_start_idx;
    int num = h.poly_num;

    for (int i = 0; i < num; i++)
    {
        if (hittable_hit_triangle(state, h, Polygons[start + i], r, interval_new(ray_t.min, closest_so_far), temp_rec)){
            hit_anything = true;
            closest_so_far = temp_rec.t;
            rec = temp_rec;
        }
    }

    return hit_anything;
}

bool hittable_list_hit(inout rand_state state, const ray r, interval ray_t, inout hit_record rec)
{
    hit_record temp_rec = hit_record_new();
    bool hit_anything = false;
    float closest_so_far = ray_t.max;

    for (int i = 0; i < NumObjects; i++) //NumObjects
    {
        hit_object h = Objects[i];
        if (h.enabled != 1)
            continue;
        if (h.hittable_type == HITTABLE_TYPE_POLY){
            if (iter_poly_list(state, h, r, interval_new(ray_t.min, closest_so_far),temp_rec)){
                hit_anything = true;
                closest_so_far = temp_rec.t;
                rec = temp_rec;
            }
        }
        else{
            if (hittable_hit(state, h, r, interval_new(ray_t.min, closest_so_far),temp_rec)){
                hit_anything = true;
                closest_so_far = temp_rec.t;
                rec = temp_rec;
            }
        }
    }

    return hit_anything;
}

