    while (true)
    {
        if (depth <= 0){
            cur_color = color(0, 0, 0);
            break;
        }

        hit_record rec = hit_record_new();
        

        if (hittable_world_hit(state, r, interval_new(0.001, POS_INF), rec))
        {
            ray scattered = ray_new();
            color attenuation = color(0, 0, 0);
