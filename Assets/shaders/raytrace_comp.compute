[numthreads(8,8,1)]
void InitCamera (uint3 id : SV_DispatchThreadID)
{
    if (id.x >= Width || id.y >= Height)
        return;

    float pixel_samples_scale = 1.0 / SamplesPerPixel;
    point3 center = LookFrom;

    // Determine viewport dimensions.

    float theta = degrees_to_radians(VFOV);
    float h = tan(theta / 2.0);
    float viewport_height = 2.0f * h * FocusDist;
    float viewport_wdith = viewport_height * (float(Width)/Height);

    vec3 w = unit_vector(LookFrom - LookAt);
    vec3 u = unit_vector(cross(VUP, w));
    vec3 v = cross(w, u);


    // Calculate the vectors across the horizontal and down the vertical viewport edges.

    vec3 viewport_u = viewport_wdith * -u;
    vec3 viewport_v = viewport_height * v;



    // Calculate the horizontal and vertical delta vectors from pixel to pixel.

    vec3 pixel_delta_u = viewport_u / Width;
    vec3 pixel_delta_v = viewport_v / Height;


    // Calculate the location of the upper left pixel.

    vec3 viewport_upper_left = center - (FocusDist * w) - viewport_u/2 - viewport_v/2;
    vec3 pixel00_loc = viewport_upper_left + 0.5 * (pixel_delta_u + pixel_delta_v);

    float defocus_radius = FocusDist * tan(degrees_to_radians(DefocusAngle / 2));
    vec3 defocus_disk_u = u * defocus_radius;
    vec3 defocus_disk_v = v * defocus_radius;

    pixel_orientation m;
    m.pixel00_loc = float4(pixel00_loc, 0);
    m.pixel_delta_u = float4(pixel_delta_u, 0);
    m.pixel_delta_v = float4(pixel_delta_v, 0);
    m.defocus_disk_u = float4(defocus_disk_u, 0);
    m.defocus_disk_v = float4(defocus_disk_v, 0);
    PixelMeta[C_2D_to_1D(id, Width)] = m;
    ColorAccume[C_2D_to_1D(id, Width)] = int3(0, 0, 0);
}

[numthreads(8,8,10)]
void TraceIteration(uint3 id : SV_DispatchThreadID)
{
    if (id.x >= Width || id.y >= Height || id.z >= SamplesPerRun)
        return;

    rand_state state = rand_state_new(id);
    pixel_orientation m = PixelMeta[C_2D_to_1D(state.id, Width)];
    float pixel_samples_scale = 1.0 / SamplesPerPixel;
    color pixel_color = do_trace(state, m.pixel00_loc.xyz, m.pixel_delta_u.xyz, m.pixel_delta_v.xyz, m.defocus_disk_u.xyz, m.defocus_disk_v.xyz);
    
    int idx = C_2D_to_1D(id, Width);

    InterlockedAdd(ColorAccume[idx].x, int(pixel_color.x * 1000)); 
    InterlockedAdd(ColorAccume[idx].y, int(pixel_color.y * 1000)); 
    InterlockedAdd(ColorAccume[idx].z, int(pixel_color.z * 1000)); 

    //update_color(id, pixel_color);
}

[numthreads(8,8,1)]
void Finalize(uint3 id : SV_DispatchThreadID)
{
    if (id.x >= Width || id.y >= Height)
        return;

    float pixel_samples_scale = 1.0 / SamplesPerPixel;
    int idx = C_2D_to_1D(id, Width);
    int3 intCol = ColorAccume[idx];
    color col = color(
        float(intCol.x) / 1000.0,
        float(intCol.y) / 1000.0,
        float(intCol.z) / 1000.0
    );

    write_color(id, col * pixel_samples_scale);
}



[numthreads(8,8,1)]
void CSMain (uint3 id : SV_DispatchThreadID)
{
    float pixel_samples_scale = 1.0 / SamplesPerPixel;
    point3 center = LookFrom;

    // Determine viewport dimensions.

    float theta = degrees_to_radians(VFOV);
    float h = tan(theta / 2.0);
    float viewport_height = 2.0f * h * FocusDist;
    float viewport_wdith = viewport_height * (float(Width)/Height);

    vec3 w = unit_vector(LookFrom - LookAt);
    vec3 u = unit_vector(cross(VUP, w));
    vec3 v = cross(w, u);


    // Calculate the vectors across the horizontal and down the vertical viewport edges.

    vec3 viewport_u = viewport_wdith * -u;
    vec3 viewport_v = viewport_height * v;



    // Calculate the horizontal and vertical delta vectors from pixel to pixel.

    vec3 pixel_delta_u = viewport_u / Width;
    vec3 pixel_delta_v = viewport_v / Height;


    // Calculate the location of the upper left pixel.

    vec3 viewport_upper_left = center - (FocusDist * w) - viewport_u/2 - viewport_v/2;
    vec3 pixel00_loc = viewport_upper_left + 0.5 * (pixel_delta_u + pixel_delta_v);

    float defocus_radius = FocusDist * tan(degrees_to_radians(DefocusAngle / 2));
    vec3 defocus_disk_u = u * defocus_radius;
    vec3 defocus_disk_v = v * defocus_radius;


    // Construct a camera ray originating from the defocus disk and directed at a randomly
    // sampled point around the pixel location i, j.
    int i = id.x;
    int j = id.y;

    rand_state state = rand_state_new(id);
    
    color pixel_color = color(0, 0, 0);
    for (int sample = 0; sample < SamplesPerPixel; sample++)
    {
        pixel_color += do_trace(state, pixel00_loc, pixel_delta_u, pixel_delta_v, defocus_disk_u, defocus_disk_v) * pixel_samples_scale;
    }

    write_color(id, pixel_color);

}
