            cur_color = cur_color * sky_col;
            break;
        }

        depth -= 1;
    }

    return cur_color;
}



void write_color(int3 id, color pixel_color){
    float r = pixel_color.x;
    float g = pixel_color.y;
    float b = pixel_color.z;

    interval intensity = interval_new(0.000, 0.999);
    r = interval_clamp(intensity, linear_to_gamma(r));
    g = interval_clamp(intensity, linear_to_gamma(g));
    b = interval_clamp(intensity, linear_to_gamma(b));

    Result[id.xy] = float4(r, g, b, 1.0);
}

[numthreads(8,8,1)]
void CSMain (uint3 id : SV_DispatchThreadID)
{
    float pixel_samples_scale = 1.0 / SamplesPerPixel;
    point3 center = LookFrom;

    // Determine viewport dimensions.

    float theta = degrees_to_radians(VFOV);
    float h = tan(theta / 2.0);
    float viewport_height = 2.0f * h * FocusDist;
    float viewport_wdith = viewport_height * (float(Width)/Height);

    vec3 w = unit_vector(LookFrom - LookAt);
    vec3 u = unit_vector(cross(VUP, w));
    vec3 v = cross(w, u);


    // Calculate the vectors across the horizontal and down the vertical viewport edges.

    vec3 viewport_u = viewport_wdith * -u;
    vec3 viewport_v = viewport_height * v;



    // Calculate the horizontal and vertical delta vectors from pixel to pixel.

    vec3 pixel_delta_u = viewport_u / Width;
    vec3 pixel_delta_v = viewport_v / Height;


    // Calculate the location of the upper left pixel.

    vec3 viewport_upper_left = center - (FocusDist * w) - viewport_u/2 - viewport_v/2;
    vec3 pixel00_loc = viewport_upper_left + 0.5 * (pixel_delta_u + pixel_delta_v);

    float defocus_radius = FocusDist * tan(degrees_to_radians(DefocusAngle / 2));
    vec3 defocus_disk_u = u * defocus_radius;
    vec3 defocus_disk_v = v * defocus_radius;


    // Construct a camera ray originating from the defocus disk and directed at a randomly
    // sampled point around the pixel location i, j.
    int i = id.x;
    int j = id.y;

    hittable ht = Objects[0];
    material mat = Materials[0];
    //debug[C_2D_to_1D(id, Width)] = float4(ht.center.orig.xyz, 1);

    rand_state state = rand_state_new(id);
    
    color pixel_color = color(0, 0, 0);
    for (int sample = 0; sample < SamplesPerPixel; sample++)
    {
        vec3 offset = sample_square(state);
        vec3 pixel_sample = pixel00_loc +
                            ((i + offset.x) * pixel_delta_u) +
                            ((j + offset.y) * pixel_delta_v);

        
        // Returns a random point in the camera defocus disk.
        vec3 p = random_in_unit_disk(state);
        point3 def_sample = center + (p[0] * defocus_disk_u) + (p[1] * defocus_disk_v);
        point3 ray_origin = (DefocusAngle <= 0.0001) ? center : def_sample;
        float ray_time = random_double(state);

        vec3 ray_direction = pixel_sample - ray_origin;
    
        ray r = ray_new(ray_origin, ray_direction, ray_time);
        pixel_color += ray_color(state, r, MaxDepth);
    }

    //debug[C_2D_to_1D(id, Width)] = float4(rVec.xyz,  n);

    write_color(id, pixel_color * pixel_samples_scale);



    //Result[id.xy] = float4(id.x / (float)Width, id.y / (float)Height, t, 1);
    //Result[id.xy] = float4(id.x & id.y, (id.x & 15)/15.0, (id.y & 15)/15.0, 0.0);
}
