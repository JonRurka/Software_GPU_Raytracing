bool material_scatter_none(inout rand_state state, const material mat, const ray r_in, const hit_record rec, inout color attenuation, inout ray scattered)
{
    attenuation = color(0, 0, 0);
    scattered = r_in;
    return false;
}

color material_emitted_lambertian(const material mat, float2 uv){
    return color(1, 1, 1);
}

bool material_scatter_lambertian(inout rand_state state, const material mat, const ray r_in, const hit_record rec, inout color attenuation, inout ray scattered)
{
    if (mat.does_emit)
        return false;

    vec3 ran_vec = random_unit_vector(state);
    vec3 scatter_direction = hit_record_normal(rec) + ran_vec;

    // Catch degenerate scatter direction
    if (vec3_near_zero(scatter_direction))
        scatter_direction = hit_record_normal(rec);

    scattered = ray_new(hit_record_position(rec), scatter_direction, ray_tm(r_in));
    attenuation = mat.albedo;// sample_texture(rec.uv);// mat.albedo;
    return true;
}

bool material_scatter_metal(inout rand_state state, const material mat, const ray r_in, const hit_record rec, inout color attenuation, inout ray scattered)
{
    vec3 reflected = vec3_reflect(ray_dir(r_in), hit_record_normal(rec));
    reflected = unit_vector(reflected) + (mat.fuzz * random_unit_vector(state));
    scattered = ray_new(hit_record_position(rec), reflected, ray_tm(r_in));
    attenuation = mat.albedo;
    return (dot(ray_dir(scattered), hit_record_normal(rec)) > 0);
}

float material_dielectric_reflectance(float cosine, float refraction_index) {
    // Use Schlick's approximation for reflectance.
    float r0 = (1 - refraction_index) / (1 + refraction_index);
    r0 = r0 * r0;
    return r0 + (1 - r0) * pow((1 - cosine), 5);
}

bool material_scatter_dielectric(inout rand_state state, const material mat, const ray r_in, const hit_record rec, inout color attenuation, inout ray scattered)
{
    attenuation = mat.albedo;
    float ri = hit_record_front_face_get(rec) ? (1.0 / mat.refraction_index) : (mat.refraction_index);

    vec3 rec_normal = hit_record_normal(rec);
    vec3 rec_position = hit_record_position(rec);
    vec3 direction;

    vec3 unit_direction = unit_vector(ray_dir(r_in));
    float cos_theta = min(dot(-unit_direction, rec_normal), 1.0);
    float sin_theta = sqrt(1.0 - cos_theta*cos_theta); 

    bool cannot_refract = ri * sin_theta > 1.0;
    

    if (cannot_refract || material_dielectric_reflectance(cos_theta, ri) > random_double(state))
        direction = vec3_reflect(unit_direction, rec_normal);
    else 
        direction = vec3_refract(unit_direction, rec_normal, ri);

    scattered = ray_new(rec_position, direction, ray_tm(r_in));
    return true;
}

bool material_scatter(inout rand_state state, const material mat, const ray r_in, const hit_record rec, inout color attenuation, inout ray scattered)
{
    switch(mat.material_type)
    {
        case MATERIAL_TYPE_LAMBERTIAN:
            return material_scatter_lambertian(state, mat, r_in, rec, /*out*/ attenuation, /*out*/ scattered);
            break;
        case MATERIAL_TYPE_METAL:
            return material_scatter_metal(state, mat, r_in, rec, /*out*/ attenuation, /*out*/ scattered);
            break;
        case MATERIAL_TYPE_DIELECTRIC:
            return material_scatter_dielectric(state, mat, r_in, rec, /*out*/ attenuation, /*out*/ scattered);
            break;
        default:
            return material_scatter_none(state, mat, r_in, rec, /*out*/ attenuation, /*out*/ scattered);
            break;
    }
}

bool material_emitted(const material mat, float2 uv)
{
    if (mat.does_emit == 0)
        return color(0, 0, 0);

    switch(mat.material_type)
    {
        case MATERIAL_TYPE_LAMBERTIAN:
            return material_emitted_lambertian(mat, uv);
            break;
        case MATERIAL_TYPE_METAL:
            return color(0, 0, 0);
            break;
        case MATERIAL_TYPE_DIELECTRIC:
            return color(0, 0, 0);
            break;
        default:
            return color(0, 0, 0);
            break;
    }
}

material material_get(mat_ID id)
{
    return Materials[id];
}



bool hittable_hit_triangle(inout rand_state state, const hit_object obj, const hit_poly hit, const ray r, interval ray_t, inout hit_record rec)
{
    // Möller-Trumbore method
    //vec3 pos = obj.center.orig;
    //float4x4 mat = obj.rotation;

    vec3 v0 = HIT_OBJECT_V0(hit);//(vec4(HIT_OBJECT_V0(hit), 1.0) * mat + pos).xyz;
    vec3 v1 = HIT_OBJECT_V1(hit);//(vec4(HIT_OBJECT_V1(hit), 1.0) * mat + pos).xyz;
    vec3 v2 = HIT_OBJECT_V2(hit);//(vec4(HIT_OBJECT_V2(hit), 1.0) * mat + pos).xyz;
    vec3 orig = ray_orig(r);
    vec3 dir = ray_dir(r);

    //v0 = mul(mat, vec4(v0, 1.0)).xyz + pos;
    //v1 = mul(mat, vec4(v1, 1.0)).xyz + pos;
    //v2 = mul(mat, vec4(v2, 1.0)).xyz + pos;


    vec3 v0v1 = v1 - v0;
    vec3 v0v2 = v2 - v0;
    vec3 pvec = cross(dir, v0v2);
    float det = dot(v0v1, pvec);

    const float kEplsilon = 1e-8;

    const bool culling = false;

    hit_record_uv(rec) = float2(0, 0);

    if (culling){
        // If the determinant is negative, the triangle is back-facing.
        // If the determinant is close to 0, the ray misses the triangle
        if (det < kEplsilon) return false;
    }
    else{
        // If det is close to 0, the ray and triangle are parellel
        if (abs(det) < kEplsilon) return false;
    }

    float invDet = 1 / det;

    vec3 tvec = orig - v0;
    float u = dot(tvec, pvec) * invDet;
    if (u < 0 || u > 1) return false;

    vec3 qvec = cross(tvec, v0v1);
    float v = dot(dir, qvec) * invDet;
    if (v < 0 || u + v > 1) return false;

    float t = dot(v0v2, qvec) * invDet;

    if (!interval_surrounds(ray_t, t))
        return false;

    hit_record_t(rec) = t;
    hit_record_position(rec) = ray_at(r, t);
    hit_record_uv(rec) = float2(u, v);
    vec3 outward_normal = normalize(cross(v0v1, v0v2));
    hit_record_set_face_normal(rec, r, outward_normal);
    hit_record_mat_set(rec, obj.mat);

    return true;
}

