{
    // If we've exceeded the ray bounce limit, no more light is gathered.
    //if (depth <= 0)
    //    return color(0, 0, 0);

    /*hit_record rec = hit_record_new();

    if (hittable_world_hit(state, r, interval_new(0.001, POS_INF), rec))
