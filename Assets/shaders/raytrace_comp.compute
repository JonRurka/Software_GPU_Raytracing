    color cur_color = color(1, 1, 1);
    

    //debug[C_2D_to_1D(id, Width)] = float4(0, 0, 0, 0);

    /*hit_record rec = hit_record_new();
    if (hittable_hit_sphere(state, Objects[0], r, interval_new(0.001, POS_INF), rec)){
        ray scattered = ray_new();
        color attenuation = color(0, 0, 0);
        //debug[C_2D_to_1D(id, Width)] = float4(1, material_get(rec.mat).albedo.xyz);
        //debug[C_2D_to_1D(state.id, Width)] = float4(rec.normal.xyz, 1);
        //debug[C_2D_to_1D(state.id, Width)] = float4(rec.normal.xyz, 1);
        if (material_scatter_lambertian(state, material_get(rec.mat), r, rec, attenuation,  scattered)){
