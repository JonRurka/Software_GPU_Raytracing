bool hittable_world_hit(inout rand_state state, const ray r, interval ray_t, inout hit_record rec)
{
    const int STACK_SIZE = 16;

    int stack[STACK_SIZE];
    int stack_offset = 0;
    int max_stack = 0;
    stack[stack_offset++] = 0; // root

    bool res = false;
    int hittable_idx = 0;

    hit_record temp_rec = hit_record_new();
    bool hit_anything = false;
    float closest_so_far = ray_t.max;

    int xit_reason = -1;
    float3 tst_b;

    int iter = 0;
    while(true)
    {
        iter++;
        if (stack_offset <= 0){
            //xit_reason = 1;
            break;
        }

        int idx = stack[--stack_offset];
        bvh_node node = BVH[idx];

        if (stack_offset >= STACK_SIZE || iter > 100){
            //xit_reason = 2;
            break;
        }

        if (!node.enabled || !aabb_hit(node.bounds, r, ray_t)){
            tst_b = float3(node.bounds.x.max - node.bounds.x.min, node.bounds.y.max - node.bounds.y.min, node.bounds.z.max - node.bounds.z.min);
            continue;
        }

        if (node.Leaf >= 0){
            res = true;
            hittable_idx = node.Leaf;

            hit_poly poly = TransformedPolygons[hittable_idx];
            hit_object h = Objects[poly.hit_obj_idx];

            if (h.enabled == 1 && hittable_hit_triangle(state, h, poly, r, interval_new(ray_t.min, closest_so_far), temp_rec)){
                hit_anything = true;
                closest_so_far = hit_record_t(temp_rec);
                rec = temp_rec;
                //debug[C_2D_to_1D(state.id, Width)] = float4(1, 0, iter, 0);
                //break;
            }
        }
        else {
            stack[stack_offset++] = node.right; //2 * idx + 2;
            stack[stack_offset++] = node.left; //2 * idx + 1;
        }

        max_stack = max(stack_offset, max_stack);
    }

    //debug[C_2D_to_1D(state.id, Width)] = float4(1, max_stack, iter, 0);

    return hit_anything;
}


color ray_color(inout rand_state state, ray r, int depth)
{

    color cur_color = color(1, 1, 1);
    color background_color = color(0.01, 0.01, 0.01);

    /*vec3 unit_direction = unit_vector(r.dir);
    float a = 0.5 * (unit_direction.y + 1.0);
    color sky_col = (1.0 - a) * color(1.0, 1.0, 1.0) + a * color(0.5, 0.7, 1.0);
    cur_color *= background_color;//(sky_col);
    //return cur_color;
    */

    /*hit_record rec = hit_record_new();
    if (hittable_world_hit(state, r, interval_new(0.001, POS_INF), rec)){
        ray scattered = ray_new();
        color attenuation = color(0, 0, 0);
        color col_from_emittion = material_emitted(material_get(rec.mat), rec.uv);
        if (material_scatter(state, material_get(rec.mat), r, rec, attenuation,  scattered)){
            color col_from_scatter = (cur_color * attenuation);
            cur_color = col_from_scatter + col_from_emittion;
        }
    }
    return cur_color;*/

    /*hit_record rec = hit_record_new();
    if (hittable_hit_triangle(state, Objects[0], Polygons[0], r, interval_new(0.001, POS_INF), rec) ||
        hittable_hit_triangle(state, Objects[0], Polygons[1], r, interval_new(0.001, POS_INF), rec)){
        cur_color *= color(1, 0, 0);
    }
    return cur_color;*/


    int i = 0;
    while (true)
    {
        if (depth <= 0){
            cur_color = color(0, 0, 0);
            break;
        }

        hit_record rec = hit_record_new();
        

        if (hittable_world_hit(state, r, interval_new(0.001, POS_INF), rec))
        {
            ray scattered = ray_new();
            color attenuation = color(0, 0, 0);
            color col_from_emittion = material_emitted(material_get( hit_record_mat_get(rec)), hit_record_uv(rec));
            if (material_scatter(state, material_get(hit_record_mat_get(rec)), r, rec, attenuation,  scattered)){
                color col_from_scatter = (cur_color * attenuation);
                cur_color = col_from_scatter + col_from_emittion;
                r = scattered;
            }
            else{
                cur_color *= col_from_emittion;
                break;
            }
        }
        else{
            vec3 unit_direction = unit_vector(ray_dir(r));
            float a = 0.5 * (unit_direction.y + 1.0);
            color sky_col = (1.0 - a) * color(1.0, 1.0, 1.0) + a * color(0.5, 0.7, 1.0);
            cur_color *= background_color;//(sky_col);
            break;
        }

        depth -= 1;
        i++;
    }

    return cur_color;

}

void write_color(int3 id, color pixel_color){
    float r = pixel_color.x;
    float g = pixel_color.y;
    float b = pixel_color.z;

    interval intensity = interval_new(0.000, 0.999);
    r = interval_clamp(intensity, linear_to_gamma(r));
    g = interval_clamp(intensity, linear_to_gamma(g));
    b = interval_clamp(intensity, linear_to_gamma(b));

    Result[id.xy] = float4(r, g, b, 1.0);
}

void update_color(int3 id, color pixel_color){
    float r = pixel_color.x;
    float g = pixel_color.y;
    float b = pixel_color.z;

    color cur_col = Result[id.xy].xyz;

    interval intensity = interval_new(0.000, 0.999);
    r = interval_clamp(intensity, cur_col.x + linear_to_gamma(r));
    g = interval_clamp(intensity, cur_col.y + linear_to_gamma(g));
    b = interval_clamp(intensity, cur_col.z + linear_to_gamma(b));

    Result[id.xy] = float4(r, g, b, 1.0);
}

color do_trace(inout rand_state state, vec3 pixel00_loc, vec3 pixel_delta_u, vec3 pixel_delta_v, vec3 defocus_disk_u, vec3 defocus_disk_v)
{
    int i = state.id.x;
    int j = state.id.y;

    point3 center = LookFrom;

    vec3 offset = sample_square(state);
    vec3 pixel_sample = pixel00_loc +
                        ((i + offset.x) * pixel_delta_u) +
                        ((j + offset.y) * pixel_delta_v);

    
    // Returns a random point in the camera defocus disk.
    vec3 p = random_in_unit_disk(state);
    point3 def_sample = center + (p[0] * defocus_disk_u) + (p[1] * defocus_disk_v);
    point3 ray_origin = (DefocusAngle <= 0.0001) ? center : def_sample;
    float ray_time = random_double(state);

    vec3 ray_direction = pixel_sample - ray_origin;

    ray r = ray_new(ray_origin, ray_direction, ray_time);
    return ray_color(state, r, MaxDepth);
}

[numthreads(64,1,1)]
void TransformPolygons(uint3 id : SV_DispatchThreadID)
{
    if (id.x >= NumPoly)
        return;

    hit_poly p = Polygons[id.x];
    hit_object obj = Objects[p.hit_obj_idx];

    vec3 pos = ray_orig(obj.center);
    float4x4 mat = obj.rotation;

    vec3 v0 = HIT_OBJECT_V0(p);
    vec3 v1 = HIT_OBJECT_V1(p);
    vec3 v2 = HIT_OBJECT_V2(p);

    v0 = mul(mat, vec4(v0, 1.0)).xyz + pos;
    v1 = mul(mat, vec4(v1, 1.0)).xyz + pos;
    v2 = mul(mat, vec4(v2, 1.0)).xyz + pos;


    HIT_OBJECT_V0(p) = v0;
    HIT_OBJECT_V1(p) = v1;
    HIT_OBJECT_V2(p) = v2;

    p.attr1.w = id.x;

    TransformedPolygons[id.x] = p;
}

